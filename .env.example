# Website env (copy to .env.local)
NEXT_PUBLIC_SUPABASE_URL=
NEXT_PUBLIC_SUPABASE_ANON_KEY=
# Comma-separated admin emails for web admin access
NEXT_PUBLIC_ADMIN_EMAILS=admin@yourdomain.com

# Server-side Supabase (enables admin APIs, IPN processing, receipts, analytics)
SUPABASE_URL=
SUPABASE_SERVICE_ROLE_KEY=

# Pesapal config (demo mode requires no keys)
PESAPAL_MODE=demo
PESAPAL_CONSUMER_KEY=
PESAPAL_CONSUMER_SECRET=

# Optional email SMTP (if provided, system will send emails)
SMTP_HOST=
SMTP_USER=
SMTP_PASS=
SMTP_FROM=
